{
  "name": "caseforge-ai-test-generator",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered PRD parser and functional test case generator for QA workflows.",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node --watch server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start:api": "node server/index.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "openai": "^6.44.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.4",
    "@tailwindcss/vite": "4.1.4",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "tailwindcss": "4.1.4",
    "typescript": "~5.8.3",
    "vite": "^6.2.6"
  }
}
